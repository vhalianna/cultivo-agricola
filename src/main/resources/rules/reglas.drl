package rules;
import com.val.drools.SituacionAgricola;
dialect "java"

// ==========================================
// SECCIÓN 1: ENMIENDA Y FERTILIZACIÓN
// ==========================================

rule "R1: Aplicar cal en maiz con pH bajo"
    no-loop true
when
    $s : SituacionAgricola(
            cultivo == "MAIZ",
            ph_suelo == "BAJO",
            enmienda_suelo == "NINGUNA"
        )
then
    $s.setEnmienda_suelo("CAL");
    update($s);
end

rule "R5: Fertilizacion necesaria"
    no-loop true
when
    $s : SituacionAgricola(
            nutrientes == "BAJOS",
            fertilizacion != "NECESARIA",
            precipitaciones != "ALTAS" // <--- AGREGAR ESTO
        )
then
    $s.setFertilizacion("NECESARIA");
    update($s);
end

rule "R6: Fertilizacion no necesaria"
    no-loop true
when
    $s : SituacionAgricola(
            (nutrientes == "ADECUADOS" || nutrientes == "ALTOS"),
            fertilizacion != "NO_NECESARIA"
        )
then
    $s.setFertilizacion("NO_NECESARIA");
    update($s);
end

// ==========================================
// SECCIÓN 2: CONTROL DE PLAGAS
// ==========================================

rule "R2: Pesticida en hortalizas"
    no-loop true
when
    $s : SituacionAgricola(
            cultivo == "HORTALIZAS",
            plaga == "INSECTOS",
            control_plaga == "NINGUNO"
        )
then
    $s.setControl_plaga("PESTICIDA");
    update($s);
end

rule "R4: Fungicida preventivo en frutales"
    no-loop true
when
    $s : SituacionAgricola(
            cultivo == "FRUTALES",
            humedad_amb == "ALTA",
            control_plaga == "NINGUNO"
        )
then
    $s.setControl_plaga("FUNGICIDA");
    update($s);
end

rule "R7: Herbicida para malezas"
    no-loop true
when
    $s : SituacionAgricola(
            plaga == "MALEZAS",
            control_plaga == "NINGUNO"
        )
then
    $s.setControl_plaga("HERBICIDA");
    // AGREGAR ESTE IF:
    if (!"INTEGRADO".equals($s.getManejo())) {
        $s.setManejo("PREVENTIVO");
    }
    update($s);
end

rule "R8: Fungicida por hongos"
    no-loop true
when
    $s : SituacionAgricola(
            plaga == "HONGOS",
            control_plaga == "NINGUNO"
        )
then
    $s.setControl_plaga("FUNGICIDA");
    update($s);
end

rule "R9: Insecticida general"
    no-loop true
when
    $s : SituacionAgricola(
            plaga == "INSECTOS",
            cultivo != "HORTALIZAS",
            control_plaga == "NINGUNO"
        )
then
    $s.setControl_plaga("INSECTICIDA");
    update($s);
end

// ==========================================
// SECCIÓN 3: RIEGO Y SEGURIDAD
// ==========================================

rule "R3: Aumentar frecuencia por calor"
    no-loop true
when
    $s : SituacionAgricola(
            temperatura == "ALTA",
            humedad_suelo == "BAJA",
            riego == "NORMAL"
        )
then
    $s.setRiego("AUMENTAR_FRECUENCIA");
    update($s);
end

rule "R10: Aumentar caudal por sequia"
    no-loop true
when
    $s : SituacionAgricola(
            precipitaciones == "BAJAS",
            humedad_suelo == "BAJA",
            riego == "NORMAL"
        )
then
    $s.setRiego("AUMENTAR_CAUDAL");
    update($s);
end

rule "R20: Bloqueo de Riego por Aplicacion Quimica"
    salience 1000
    no-loop true
when
    $s : SituacionAgricola(
            // AHORA PROTEGEMOS TODOS LOS QUÍMICOS:
            (control_plaga == "FUNGICIDA" ||
             control_plaga == "HERBICIDA" ||
             control_plaga == "INSECTICIDA" ||
             control_plaga == "PESTICIDA"),
            riego != "MANTENER"
        )
then
    $s.setRiego("MANTENER");
    update($s);
end

// ==========================================
// SECCIÓN 4: DIAGNÓSTICO DE RIESGO
// ==========================================

rule "R11: Riesgo Medio por Historial Alto"
    no-loop true
when
    $s : SituacionAgricola(
            historial_plagas == "ALTO",
            plaga == "NINGUNA",
            riesgo != "ALTO"
        )
then
    $s.setRiesgo("MEDIO");
    update($s);
end

rule "R12: Riesgo Alto"
    no-loop true
when
    $s : SituacionAgricola(
            plaga != "NINGUNA",
            (historial_plagas == "ALTO" || historial_plagas == "MEDIO"),
            riesgo != "ALTO"
        )
then
    $s.setRiesgo("ALTO");
    update($s);
end

rule "R13: Riesgo Medio por Historial Medio"
    no-loop true
when
    $s : SituacionAgricola(
            historial_plagas == "MEDIO",
            plaga == "NINGUNA",
            riesgo != "ALTO"
        )
then
    $s.setRiesgo("MEDIO");
    update($s);
end

rule "R14: Riesgo Bajo"
    no-loop true
when
    $s : SituacionAgricola(
            historial_plagas == "BAJO",
            plaga == "NINGUNA",
            riesgo != "BAJO",
            // AGREGAR ESTAS 3 LINEAS (Son las condiciones de la R25 negadas):
            ph_suelo != "BAJO",
            ph_suelo != "ALTO",
            nutrientes != "BAJOS"
        )
then
    $s.setRiesgo("BAJO");
    update($s);
end

rule "R15: Riesgo Medio por Plaga con Historial Bajo"
    no-loop true
when
    $s : SituacionAgricola(
            plaga != "NINGUNA",
            historial_plagas == "BAJO",
            riesgo == "BAJO"
        )
then
    $s.setRiesgo("MEDIO");
    update($s);
end

// ==========================================
// SECCIÓN 5: ESTRATEGIA DE MANEJO
// ==========================================

rule "R16: Manejo Integrado por Riesgo Alto"
    salience 1000
    no-loop true
when
    $s : SituacionAgricola(
            riesgo == "ALTO",
            manejo != "INTEGRADO"
        )
then
    $s.setManejo("INTEGRADO");
    update($s);
end

rule "R17: Manejo Preventivo por Riesgo Medio"
    salience 10
    no-loop true
when
    $s : SituacionAgricola(
            riesgo == "MEDIO",
            manejo != "INTEGRADO",
            manejo != "PREVENTIVO"
        )
then
    $s.setManejo("PREVENTIVO");
    update($s);
end

rule "R19: Manejo Preventivo por Cal"
    salience 500
    no-loop true
when
    $s : SituacionAgricola(
            enmienda_suelo == "CAL",
            manejo != "INTEGRADO",
            manejo != "PREVENTIVO"
        )
then
    $s.setManejo("PREVENTIVO");
    update($s);
end

rule "R18: Manejo Convencional por Riesgo Bajo"
    salience 0
    no-loop true
when
    $s : SituacionAgricola(
            riesgo == "BAJO",
            manejo != "INTEGRADO",
            manejo != "PREVENTIVO",
            manejo != "CONVENCIONAL"
        )
then
    $s.setManejo("CONVENCIONAL");
    update($s);
end

// ==========================================
// SECCIÓN 6: ALERTAS Y CONFLICTOS
// ==========================================

rule "R21: Alerta por condiciones fuera de rango"
    no-loop true
when
    $s : SituacionAgricola(
            (ph_suelo == "ALTO" || (humedad_amb == "ALTA" && cultivo != "FRUTALES")),
            alerta != "SI"
        )
then
    $s.setAlerta("SI");
    update($s);
end

// R22: CONSERVADA - Resuelve conflicto físico (Frío vs Agua)
rule "R22: Bloqueo de Riego por Baja Temperatura"
    salience 2000
    no-loop true
when
    $s : SituacionAgricola(
            temperatura == "BAJA",
            riego != "DISMINUIR"
        )
then
    $s.setRiego("DISMINUIR");
    update($s);
end

// R23: CONSERVADA - Resuelve conflicto operativo (Frío vs Químico)
rule "R23: Prohibir Aplicacion de Quimicos por Frio"
    salience 2000
    no-loop true
when
    $s : SituacionAgricola(
            temperatura == "BAJA",
            control_plaga != "NINGUNO",
            control_plaga != "MONITOREO"
        )
then
    $s.setControl_plaga("MONITOREO");
    update($s);
end

// R24: CONSERVADA - Resuelve conflicto ambiental (Lluvia vs Químico)
rule "R24: Posponer Quimicos por Lluvia"
    salience 2000
    no-loop true
when
    $s : SituacionAgricola(
            precipitaciones == "ALTAS",
            control_plaga != "NINGUNO",
            control_plaga != "MONITOREO"
        )
then
    $s.setControl_plaga("MONITOREO");
    update($s);
end

// R25: CONSERVADA - Resuelve conflicto de jerarquía (Abiótico vs Biótico)
// Nota: Quitamos la parte de pH ALTO si querías ser estricto,
// pero es mejor dejarla para diagnosticar RIESGO ALTO aunque no tengamos cura.
rule "R25: Riesgo Alto por Colapso Abiotico"
    salience 500
    no-loop true
when
    $s : SituacionAgricola(
            plaga == "NINGUNA",
            riesgo == "BAJO",
            (ph_suelo == "BAJO" || ph_suelo == "ALTO" || nutrientes == "BAJOS")
        )
then
    $s.setRiesgo("ALTO");
    $s.setManejo("INTEGRADO");
    update($s);
end